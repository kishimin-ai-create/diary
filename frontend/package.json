{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:small": "vitest run --reporter=verbose small.test",
    "test:medium": "vitest run --reporter=verbose medium.test",
    "test:large": "vitest run --reporter=verbose large.test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "vrt:capture": "storycap --serverCmd \"bun run build-storybook && bunx serve storybook-static -p 6006\" http://localhost:6006",
    "vrt": "reg-suit run",
    "api:generate": "orval"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-devtools": "^5.100.14",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/nextjs": "^10.4.1",
    "@storybook/test": "^8.6.15",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/eslint-plugin": "^1.6.18",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-storybook": "^10.4.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.7",
    "orval": "^8.14.0",
    "prettier": "^3.8.3",
    "reg-publish-filesystem-plugin": "^0.2.0",
    "reg-simple-keygen-plugin": "^0.14.2",
    "reg-suit": "^0.14.5",
    "storybook": "^10.4.1",
    "storycap": "^5.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8.60.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.7"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ],
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}