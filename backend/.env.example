# ============================================================
# Application
# ============================================================
NODE_ENV=development
PORT=3000
JWT_SECRET=change_me_to_a_long_random_secret

# ============================================================
# Database (PostgreSQL)
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=diary_db
DB_USER=diary_user
DB_PASSWORD=your_password_here

# Full DSN (alternative to individual vars - used by Drizzle)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://diary_user:your_password_here@localhost:5432/diary_db
