# ============================================================
# Application
# ============================================================
NODE_ENV=development
PORT=3000

# ============================================================
# Database (MySQL)
# ============================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=diary_db
DB_USER=diary_user
DB_PASSWORD=your_password_here
DB_CONNECTION_LIMIT=10

# Full DSN (alternative to individual vars — used by Drizzle)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://diary_user:your_password_here@localhost:3306/diary_db
