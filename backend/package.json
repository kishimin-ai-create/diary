    "@typescript/native-preview": "^7.0.0-dev.20260527.2",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/eslint-plugin": "^1.6.18",
    "drizzle-kit": "^0.31.10",
    "drizzle-zod": "^0.8.3",
    "eslint": "^10.4.1",
